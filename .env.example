# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.

# Supabase (from Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# News APIs
THE_NEWS_API_TOKEN=your-thenewsapi-token
GNEWS_API_KEY=your-gnews-key

# Admin access control (GitHub username allowed to access /admin)
ALLOWED_GITHUB_USERNAME=your-github-username

# Route revalidation (any random secure string)
REVALIDATE_SECRET=your-revalidation-secret

# Site URL (http://localhost:3000 for dev, https://salesmansolutions.net for prod)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
